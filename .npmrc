# Vercel is using pnpm for installs in this project.
# Some deps have strict peer ranges, so we relax peer dependency enforcement to avoid install failures.
strict-peer-dependencies=false
auto-install-peers=true

# Vercel runs pnpm with a frozen lockfile in CI by default. Our repo may have an outdated pnpm-lock.yaml,
# so we explicitly allow pnpm to proceed.
frozen-lockfile=false